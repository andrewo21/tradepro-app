# -------------------------------------------------------
# .env.local — Stripe TEST MODE configuration
# Copy this to .env.local and fill in your values.
# -------------------------------------------------------

# ------ STRIPE (Test Mode) ------
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_...          # Stripe Dashboard > Developers > API Keys
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe Dashboard > Webhooks > your endpoint
STRIPE_PRICE_ID_RESUME=price_...                       # $14.99 — Resume Only
STRIPE_PRICE_ID_COVER_LETTER=price_...                 # $8.99  — Cover Letter Only
STRIPE_PRICE_ID_BUNDLE=price_...                       # $29.99 — Full Premium Bundle
STRIPE_PRICE_ID_UPGRADE_RESUME_TO_BUNDLE=price_...       # $15.00 — Upgrade: Resume → Bundle
STRIPE_PRICE_ID_UPGRADE_COVER_LETTER_TO_BUNDLE=price_... # $21.00 — Upgrade: Cover Letter → Bundle
STRIPE_PRICE_ID_UPGRADE_BOTH_TO_BUNDLE=price_...         # $6.01  — Upgrade: Resume + Cover Letter → Bundle

# ------ OVERRIDE SWITCHES ------
# Default is false on Vercel (no env var = Stripe required).
# Set to "true" only to bypass Stripe for a specific user/founder.
# OVERRIDE_ACCESS=true
# OVERRIDE_PREMIUM=true

# ------ TEST PANEL (Pricing Page) ------
# Shows the amber debug panel on /pricing so you can see entitlement state and reset between runs.
NEXT_PUBLIC_STRIPE_TEST_MODE=true

# ------ LOCAL DEV (bypass Stripe locally without these vars) ------
# Setting this to true re-enables the free-access bypass for local development only.
NEXT_PUBLIC_DEV_MODE=true

# ------ BRAZIL PORTAL (BRL prices — create in Stripe live mode) ------
STRIPE_BR_PRICE_ID_RESUME=price_...        # R$ 79 — Currículo Padrão
STRIPE_BR_PRICE_ID_COVER_LETTER=price_...  # R$ 39 — Carta de Apresentação
STRIPE_BR_PRICE_ID_BUNDLE=price_...        # R$ 149 — Pacote Premium

# ------ AI / EXPRESS SERVER ------
NEXT_PUBLIC_API_URL=http://localhost:3001
OPENAI_API_KEY=sk-...
