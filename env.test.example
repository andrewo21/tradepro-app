# -------------------------------------------------------
# .env.local — Stripe TEST MODE configuration
# Copy this to .env.local and fill in your values.
# -------------------------------------------------------

# ------ STRIPE (Test Mode) ------
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_...          # Stripe Dashboard > Developers > API Keys
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe Dashboard > Webhooks > your endpoint
STRIPE_PRICE_ID_RESUME=price_...       # Stripe Dashboard > Products > Resume Only
STRIPE_PRICE_ID_COVER_LETTER=price_... # Stripe Dashboard > Products > Cover Letter Only
STRIPE_PRICE_ID_BUNDLE=price_...       # Stripe Dashboard > Products > Full Premium Bundle

# ------ OVERRIDE SWITCHES ------
# Set both to "false" to disable the dev bypass and require real Stripe purchases.
# Set to "true" (or omit) to unlock everything without payment (founder/dev mode).
OVERRIDE_ACCESS=false
OVERRIDE_PREMIUM=false

# ------ TEST PANEL (Pricing Page) ------
# Shows the amber debug panel on /pricing so you can see entitlement state and reset between runs.
NEXT_PUBLIC_STRIPE_TEST_MODE=true

# ------ AI / EXPRESS SERVER ------
NEXT_PUBLIC_API_URL=http://localhost:3001
OPENAI_API_KEY=sk-...

# ------ DEV MODE (optional) ------
# NEXT_PUBLIC_DEV_MODE=false
